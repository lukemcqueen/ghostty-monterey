theme = catppuccin-mocha
font-size = 14
font-family = JetBrains Mono
font-family = Fira Code
font-family = Menlo
font-family = monospace
copy-on-select = clipboard

# Split panes
# Create splits
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
# Alternative: super+\ for vertical, super+- for horizontal (visually intuitive)
keybind = super+backslash=new_split:right
keybind = super+minus=new_split:down

# Navigate splits with super+alt+arrows
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:up
keybind = super+alt+down=goto_split:down

# Resize splits with super+ctrl+arrows
keybind = super+ctrl+left=resize_split:left,10
keybind = super+ctrl+right=resize_split:right,10
keybind = super+ctrl+up=resize_split:up,10
keybind = super+ctrl+down=resize_split:down,10

# Toggle split zoom
keybind = super+shift+enter=toggle_split_zoom

# Equalize splits
keybind = super+ctrl+equal=equalize_splits
